# Copy to .env.local (gitignored), then restart `next dev`.
#
# Where the local Patchback API runs (`patchback dev` default):
NEXT_PUBLIC_PATCHBACK_API_URL=http://127.0.0.1:8787
#
# The INSIDER dev key from the `patchback dev` banner. It is minted fresh
# on every run (session-local capability, not a user secret) — re-copy it
# after restarting `patchback dev`. Without it, submissions land as
# outsider tier: data only, never a patch job.
NEXT_PUBLIC_PATCHBACK_API_KEY=
