# Copy to .env.local (gitignored), then restart `vite`.
#
# Where the local Patchback API runs (`patchback dev` default):
VITE_PATCHBACK_API_URL=http://127.0.0.1:8787
#
# The INSIDER dev key from the `patchback dev` banner. Minted fresh on
# every run — re-copy it after restarting `patchback dev`. Without it,
# submissions land as outsider tier: data only, never a patch job.
VITE_PATCHBACK_API_KEY=
