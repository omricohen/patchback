# Patchback local dev — copy to .env and fill in. Never commit .env.

# GitHub fine-grained personal access token.
# Minimum scopes are documented in packages/github/README.md (Phase 3).
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key for the default Claude Code agent adapter.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxx

# Target repository for generated PRs, e.g. "your-org/your-repo".
PATCHBACK_REPO=owner/repo

# Optional: Postgres + Redis for production mode. Local dev (`npx patchback dev`)
# uses in-memory/SQLite drivers and needs neither.
# DATABASE_URL=postgres://user:pass@localhost:5432/patchback
# REDIS_URL=redis://localhost:6379
