{
  "name": "@patchback/widget",
  "version": "0.2.0",
  "description": "Vanilla embeddable feedback widget",
  "keywords": [
    "patchback",
    "feedback",
    "widget",
    "embeddable",
    "screenshot",
    "masking"
  ],
  "license": "MIT",
  "homepage": "https://github.com/omricohen/patchback/tree/main/packages/widget#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omricohen/patchback.git",
    "directory": "packages/widget"
  },
  "bugs": {
    "url": "https://github.com/omricohen/patchback/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@patchback/sdk": "workspace:*",
    "@patchback/types": "workspace:*",
    "@zumer/snapdom": "2.12.8"
  },
  "devDependencies": {
    "vite": "^8.1.4"
  }
}
