{
  "name": "@patchback/github",
  "version": "0.0.1",
  "description": "GitHub integration: issues, branches, PRs (token + App modes)",
  "keywords": [
    "patchback",
    "github",
    "pull-request",
    "issues",
    "fine-grained-token"
  ],
  "license": "MIT",
  "homepage": "https://github.com/omricohen/patchback/tree/main/packages/github#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omricohen/patchback.git",
    "directory": "packages/github"
  },
  "bugs": {
    "url": "https://github.com/omricohen/patchback/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@patchback/types": "workspace:*"
  }
}
