{
  "name": "@patchback/api",
  "version": "0.2.0",
  "description": "Fastify API: feedback, jobs, webhooks",
  "keywords": [
    "patchback",
    "feedback",
    "api",
    "fastify",
    "queue"
  ],
  "license": "MIT",
  "homepage": "https://github.com/omricohen/patchback/tree/main/packages/api#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omricohen/patchback.git",
    "directory": "packages/api"
  },
  "bugs": {
    "url": "https://github.com/omricohen/patchback/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./drizzle": {
      "types": "./dist/store/drizzle/store.d.ts",
      "default": "./dist/store/drizzle/store.js"
    },
    "./bullmq": {
      "types": "./dist/queue/bullmq.d.ts",
      "default": "./dist/queue/bullmq.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@patchback/agent-core": "workspace:*",
    "@patchback/github": "workspace:*",
    "@patchback/triage": "workspace:*",
    "@patchback/types": "workspace:*",
    "bullmq": "^5.80.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10"
  }
}
