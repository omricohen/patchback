{
  "name": "@patchback/react",
  "version": "0.2.0",
  "description": "React wrapper and hooks for the Patchback widget",
  "keywords": [
    "patchback",
    "feedback",
    "widget",
    "react",
    "hooks"
  ],
  "license": "MIT",
  "homepage": "https://github.com/omricohen/patchback/tree/main/packages/react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omricohen/patchback.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/omricohen/patchback/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@patchback/widget": "workspace:*",
    "@patchback/types": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  }
}
